# App
APP_NAME="Order & Subscription Management System"
DEBUG=true
LOG_LEVEL=INFO

# Database — single database for everything
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/osms_app

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=osms

# PayMongo
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=

# Seed / Default Tenant & Admin
SEED_TENANT_ID=00000000-0000-0000-0000-000000000001
SEED_TENANT_NAME=Default Tenant
SEED_TENANT_SLUG=default
SEED_BUSINESS_NAME=Default Business
SEED_TIMEZONE=Asia/Manila
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=User
